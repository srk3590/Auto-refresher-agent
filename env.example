# Authentication Configuration
AUTH_USERNAME=your_username_here
AUTH_PASSWORD=your_password_here

# API Endpoint for authentication
# Replace with your actual authentication endpoint
AUTH_API_ENDPOINT=https://auth.talarianweb.com/api/v1/authenticate

# Refresh interval (cron expression)
# Default: Every 30 minutes
# Examples:
#   */15 * * * * = Every 15 minutes
#   */30 * * * * = Every 30 minutes
#   0 * * * * = Every hour
#   0 */2 * * * = Every 2 hours
REFRESH_INTERVAL=*/30 * * * *

# Optional: Path to token service file (relative to this directory)
# TOKEN_SERVICE_PATH=../../libs/core/src/lib/services/token.service.ts
